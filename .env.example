# ── Database (new Supabase project) ──────────────────────────────────────────
# Prisma pooled connection (Supabase → Connection Pooling → Transaction, port 6543)
DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true"
# Prisma direct connection for migrations (Supabase → Direct, port 5432)
DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres"

# ── Auth secrets (each min 32 chars, generate fresh) ─────────────────────────
# Generate each: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MANUFACTURER_SECRET=""
STORE_SECRET=""
MANAGER_SECRET=""
BRANCH_MANAGER_SECRET=""   # Store Manager (branch) login. Set it in production.
COOKIE_TTL_SECONDS="28800"

# ── AWS object storage ───────────────────────────────────────────────────────
# Production EC2 uses its IAM role; do not add long-lived AWS keys.
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""
# CloudFront distribution URL, without a trailing slash.
S3_PUBLIC_BASE_URL=""

# ── Vector search (similar image) ────────────────────────────────────────────
# EMBEDDER_URL now points at the AI-Features Space (embedder is merged into it).
EMBEDDER_URL=""
EMBEDDER_API_KEY=""
# Similarity vectors are stored in the PostgreSQL pgvector extension.

# ── AI-Features service (catalog image + transparent PNG + name/description) ──
# Same HF Space as EMBEDDER_URL (one service, all AI). Optional: unset = manual add.
AI_FEATURES_URL=""
AI_FEATURES_API_KEY=""

# ── Email (password reset + optional order confirmation) ─────────────────────
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL=""
FROM_NAME="Jewel Factory"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Deploy ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"
NODE_ENV="development"
# Render sets PORT (its start command binds to it). Local dev ignores it.
PORT="10000"

# =============================================================================
#  Per-platform deploy env files (gitignored — hold real secrets, paste-source):
#    .env.render  → Render production values  (this branch: renderdep)
#    .env.vercel  → Vercel production values  (branch: verceldep)
#  Copy those KEY=VALUE lines into the platform's dashboard. Never commit them.
# =============================================================================
