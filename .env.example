# ── Database (new Supabase project) ──────────────────────────────────────────
# Prisma pooled connection (Supabase → Connection Pooling → Transaction, port 6543)
DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true"
# Prisma direct connection for migrations (Supabase → Direct, port 5432)
DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres"

# ── Auth secrets (each min 32 chars, generate fresh) ─────────────────────────
MANUFACTURER_SECRET=""
STORE_SECRET=""
MANAGER_SECRET=""
COOKIE_TTL_SECONDS="28800"

# ── Cloudinary (image storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Vector search (similar image) ────────────────────────────────────────────
EMBEDDER_URL=""
EMBEDDER_API_KEY=""
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_MANUFACTURER_COLLECTION="jewelfactory_manufacturer_products"

# ── Email (password reset + optional order confirmation) ─────────────────────
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL=""
FROM_NAME="Jewel Factory"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Deploy ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"
NODE_ENV="development"
